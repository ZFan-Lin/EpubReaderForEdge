```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
.venv/
venv/
node_modules/
.julia/
.zig-cache/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# OS specific
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/
```