```gitignore
# Compiled and binary files
*.pyc
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
__pycache__/
dist/
build/
target/
.gradle/

# Editors/IDE
.vscode/
.idea/
*.swp
*.swo

# System/Environment
.DS_Store
Thumbs.db
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
.mypy_cache/
.pytest_cache/
*.pyc
__pycache__/

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.min.js
*.min.css
bundle.js
bundle.css

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```